<%- include('../partials/header') %>

    <!-- Breadcrumb Section Begin -->
    <section class="breadcrumb-section set-bg" data-setbg="/img/breadcrumb.jpg">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 text-center">
                    <div class="breadcrumb__text">
                        <h2>Users</h2>
                        <div class="breadcrumb__option">
                            <a href="./index.ejs">Home</a>
                            <span>Users</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Breadcrumb Section End -->




    <!-- Product Section Begin -->
    <section class="shoping-cart spad">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="shoping__cart__table">
                        <table>
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Admin</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(user=> { %>
                                    <tr>
                                        <td class="admin_product_img">
                                            <%= user.name %>
                                        </td>
                                        <td class="admin_product_name">
                                            <h5>
                                                <%= user.email %>
                                            </h5>
                                        </td>
                                        <td class="sadmin_product_price">
                                            <%= user.isAdmin ? "Yes" : "No" %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </section>
    <!-- Product Section End -->
    <%- include('../partials/footer') %>