
<%- include('../partials/header') %>

    <!-- Breadcrumb Section Begin -->
    <section class="breadcrumb-section set-bg" data-setbg="/img/breadcrumb.jpg">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 text-center">
                    <div class="breadcrumb__text">
                        <h2>Product</h2>
                        <div class="breadcrumb__option">
                            <a href="./index.ejs">Home</a>
                            <span>Product</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Breadcrumb Section End -->




    <!-- Product Section Begin -->
    <section class="shoping-cart spad">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="shoping__cart__table">
                        <table>
                            <thead>
                                <tr>
                                    <th class="shoping__product">Products</th>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>Action</th>

                                </tr>
                            </thead>
                            <tbody>
                                <% products.forEach(product=> { %>
                                    <tr>
                                        <td class="admin_product_img">
                                            <img src="/uploads/<%= product.image %>" width="80" alt="">
                                        </td>
                                        <td class="admin_product_name">
                                            <h5>
                                                <%= product.name %>
                                            </h5>
                                        </td>
                                        <td class="sadmin_product_price">
                                            <%= product.price %>
                                        </td>
                                        <td class="admin_product_action">
                                            <div class="edit">
                                                <div>
                                                    <a href="/admin/edit-product/<%= product._id %>">
                                                        Edit
                                                    </a>

                                                    |

                                                    <a href="/admin/delete-product/<%= product._id %>"
                                                        onclick="return confirm('Delete this product?')">
                                                        Delete
                                                    </a>
                                                </div>
                                            </div>
                                        </td>

                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </section>
    <!-- Product Section End -->
    <%- include('../partials/footer') %>

